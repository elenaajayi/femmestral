# Mistral - fine-tuning + inference
MISTRAL_API_KEY=

# NVIDIA NIM - vision (OCR), ASR, content safety
NVIDIA_API_KEY=

# Eleven Labs - TTS audio responses
ELEVEN_LABS_API_KEY=

# W&B - training logs + inference tracing
WANDB_API_KEY=
WANDB_PROJECT=femmestral

# PubMed E-utilities - free key, bumps rate limit from 3 to 10 req/sec
NCBI_API_KEY=

# Google Gemini — image OCR + Google Search grounding
GEMINI_API_KEY=

# HuggingFace — required for judges to validate your fine-tuned model
HF_TOKEN=
HF_REPO=elenaajayi/femmestral-ministral-7b

# Fine-tuned model ID (set after fine_tune.py completes)
FINE_TUNED_MODEL_ID=

# App config
APP_ENV=development
LOG_LEVEL=INFO
